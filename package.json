{
  "name": "wildbound",
  "version": "1.0.0",
  "description": "WildBound — Open World Creature Hunting Game",
  "scripts": {
    "start": "cd mobile && npx expo start",
    "android": "cd mobile && npx expo start --android",
    "ios": "cd mobile && npx expo start --ios",
    "web": "cd mobile && npx expo start --web",
    "server": "node server.js",
    "install:all": "npm install && cd mobile && npm install --legacy-peer-deps"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
